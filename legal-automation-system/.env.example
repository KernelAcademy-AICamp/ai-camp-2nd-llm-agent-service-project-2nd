# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# ============================================
# Application Settings
# ============================================
PROJECT_NAME="Legal Automation System"
VERSION="1.0.0"
ENVIRONMENT="development"  # development, staging, production
DEBUG=True
API_V1_STR="/api/v1"
BACKEND_CORS_ORIGINS=["http://localhost:8501", "http://localhost:3000"]

# ============================================
# Security
# ============================================
SECRET_KEY="your-secret-key-here-change-in-production"
JWT_SECRET_KEY="your-jwt-secret-key-change-in-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# Database Configuration
# ============================================
# PostgreSQL
DATABASE_URL="postgresql+asyncpg://legal_user:legal_pass@localhost:5432/legal_db"
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30

# Redis Cache
REDIS_URL="redis://localhost:6379/0"
REDIS_POOL_SIZE=10
CACHE_TTL=3600  # seconds

# ============================================
# AI/LLM API Keys
# ============================================
# OpenAI
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_MODEL="gpt-4"
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# Anthropic Claude
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"
ANTHROPIC_MODEL="claude-3-opus-20240229"
ANTHROPIC_MAX_TOKENS=2000

# Google AI
GOOGLE_API_KEY="your-google-api-key"
GEMINI_MODEL="gemini-pro"

# ============================================
# Vector Database (Pinecone)
# ============================================
PINECONE_API_KEY="your-pinecone-api-key"
PINECONE_ENVIRONMENT="us-west1-gcp"
PINECONE_INDEX_NAME="legal-docs"
PINECONE_DIMENSION=768
PINECONE_METRIC="cosine"

# ============================================
# Korean Law API
# ============================================
LAW_API_KEY="your-law-api-key"
LAW_API_BASE_URL="https://www.law.go.kr/DRF/lawService.do"
LAW_UPDATE_INTERVAL_DAYS=7

# ============================================
# OCR Settings
# ============================================
TESSERACT_PATH="/usr/bin/tesseract"
TESSERACT_LANG="kor+eng"
EASYOCR_LANGS=["ko", "en"]
OCR_TIMEOUT=60  # seconds

# ============================================
# Storage
# ============================================
UPLOAD_DIR="./data/uploads"
DOCUMENT_DIR="./data/documents"
TEMPLATE_DIR="./data/templates"
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# ============================================
# Email Configuration (Optional)
# ============================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="Legal AI <noreply@legal.ai>"
SMTP_TLS=True

# ============================================
# Monitoring & Logging
# ============================================
LOG_LEVEL="INFO"
LOG_FORMAT="json"
LOG_FILE="./logs/app.log"
SENTRY_DSN=""  # Optional: Sentry error tracking

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================
# Scheduler Settings
# ============================================
SCHEDULER_ENABLED=True
LAW_CRAWL_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_SCHEDULE="0 3 * * 0"  # Weekly on Sunday at 3 AM

# ============================================
# Feature Flags
# ============================================
ENABLE_OCR=True
ENABLE_RISK_ANALYSIS=True
ENABLE_LAW_CRAWLER=True
ENABLE_AI_RECOMMENDATIONS=True
ENABLE_DOCUMENT_COMPARISON=True

# ============================================
# External Services (Optional)
# ============================================
# AWS S3 (for document storage)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-northeast-2"
S3_BUCKET_NAME="legal-documents"

# Google Cloud (for additional services)
GOOGLE_CLOUD_PROJECT=""
GOOGLE_APPLICATION_CREDENTIALS=""

# ============================================
# Development/Testing
# ============================================
TEST_DATABASE_URL="sqlite:///./test.db"
MOCK_LLM_RESPONSES=False
SKIP_AUTH=False  # DANGER: Only for development